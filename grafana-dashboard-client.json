            "targets": [
                {
                    "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
                    "query": "SELECT count(\"event\") FROM \"tcpgeo_connection\" WHERE \"client\" = '$client' AND $timeFilter GROUP BY time($__interval) fill(0)",
                    "rawQuery": true,
                    "refId": "A",
                    "resultFormat": "time_series"
                }
            ]
        },
        {
