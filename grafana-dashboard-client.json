            "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
            "gridPos": {"h": 9, "w": 14, "x": 10, "y": 12},
            "fieldConfig": {
                "defaults": {
                    "color": {"mode": "palette-classic-by-name"},
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {"color": "green", "value": null},
                            {"color": "yellow", "value": 50},
                            {"color": "red", "value": 200}
                        ]
                    },
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
                "orientation": "horizontal",
                "displayMode": "gradient",
                "valueMode": "color",
                "showUnfilled": true,
                "minVizWidth": 8,
                "minVizHeight": 25,
                "namePlacement": "auto"
            },
            "targets": [
                {
                    "alias": "$tag_label",
                    "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
                    "query": "SELECT last(\"count\") FROM \"tcpgeo_client_detail\" WHERE \"client\" = '$client' AND $timeFilter GROUP BY \"label\"",
                    "rawQuery": true,
                    "refId": "A",
                    "resultFormat": "time_series"
                }
            ]
        },
        {
            "id": 9,
            "type": "table",
            "title": "Verbindungsdetail",
            "description": "Detaillierte Aufschlüsselung: Land, Stadt, Port, Dienst, Verbindungen und Traffic",
            "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
            "gridPos": {"h": 10, "w": 24, "x": 0, "y": 21},
            "fieldConfig": {
                "defaults": {
                    "color": {"mode": "thresholds"},
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [{"color": "green", "value": null}]
                    },
                    "custom": {
                        "align": "auto",
                        "cellOptions": {"type": "auto"},
                        "inspect": false,
                        "filterable": true
                    }
                },
                "overrides": [
                    {
                        "matcher": {"id": "byName", "options": "Bytes"},
                        "properties": [
                            {"id": "unit", "value": "decbytes"}
                        ]
                    },
                    {
                        "matcher": {"id": "byName", "options": "Verbindungen"},
                        "properties": [
                            {
                                "id": "custom.cellOptions",
                                "value": {"type": "color-background", "mode": "gradient"}
                            },
                            {
                                "id": "color",
                                "value": {"mode": "continuous-blues"}
                            }
                        ]
                    },
                    {
                        "matcher": {"id": "byName", "options": "Bytes"},
                        "properties": [
                            {
                                "id": "custom.cellOptions",
                                "value": {"type": "color-background", "mode": "gradient"}
                            },
                            {
                                "id": "color",
                                "value": {"mode": "continuous-oranges"}
                            },
                            {"id": "unit", "value": "decbytes"}
                        ]
                    },
                    {
                        "matcher": {"id": "byName", "options": "Land"},
                        "properties": [
                            {"id": "custom.width", "value": 160}
                        ]
                    },
                    {
                        "matcher": {"id": "byName", "options": "Stadt"},
                        "properties": [
                            {"id": "custom.width", "value": 140}
                        ]
                    },
                    {
                        "matcher": {"id": "byName", "options": "Port"},
                        "properties": [
                            {"id": "custom.width", "value": 80}
                        ]
                    }
                ]
            },
            "options": {
                "showHeader": true,
                "cellHeight": "sm",
                "footer": {
                    "show": true,
                    "reducer": ["sum"],
                    "countRows": false,
                    "fields": ["Verbindungen", "Bytes"]
                },
                "sortBy": [{"displayName": "Verbindungen", "desc": true}]
            },
            "targets": [
                {
                    "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
                    "query": "SELECT last(\"count\") as \"Verbindungen\", last(\"bytes\") as \"Bytes\" FROM \"tcpgeo_client_detail\" WHERE \"client\" = '$client' AND $timeFilter GROUP BY \"country\", \"city\", \"port\", \"label\"",
                    "rawQuery": true,
                    "refId": "A",
                    "resultFormat": "table"
                }
            ],
            "transformations": [
                {
                    "id": "organize",
                    "options": {
                        "excludeByName": {"Time": true},
                        "indexByName": {
                            "country": 0,
                            "city": 1,
                            "port": 2,
                            "label": 3,
                            "Verbindungen": 4,
                            "Bytes": 5
                        },
                        "renameByName": {
                            "country": "Land",
                            "city": "Stadt",
                            "port": "Port",
                            "label": "Dienst",
                            "Verbindungen": "Verbindungen",
                            "Bytes": "Bytes"
                        }
                    }
                }
            ]
        },
