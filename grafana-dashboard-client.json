    "description": "Umfassende Client-Analyse basierend auf TCPGeo MQTT-Daten in InfluxDB. Wähle einen Client per Dropdown und erhalte detaillierte Verbindungsstatistiken.",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "id": 1,
            "type": "stat",
            "title": "Verbindungen",
            "description": "Gesamtanzahl ausgehende Verbindungen des Clients",
            "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
            "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
            "fieldConfig": {
                "defaults": {
                    "color": {"fixedColor": "#3274D9", "mode": "fixed"},
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [{"color": "#3274D9", "value": null}]
                    },
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
                "orientation": "auto",
                "textMode": "auto",
                "wideLayout": true,
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "auto",
                "showPercentChange": false
            },
            "targets": [
                {
                    "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
                    "query": "SELECT last(\"connections\") FROM \"tcpgeo_outgoing_total\" WHERE \"client\" = '$client' AND $timeFilter GROUP BY time($__interval) fill(null)",
                    "rawQuery": true,
                    "refId": "A",
                    "resultFormat": "time_series"
                }
            ]
        },
        {
            "id": 2,
            "type": "stat",
            "title": "Traffic",
            "description": "Gesamter ausgehender Traffic des Clients",
            "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
            "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
            "fieldConfig": {
                "defaults": {
                    "color": {"fixedColor": "#FF9830", "mode": "fixed"},
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [{"color": "#FF9830", "value": null}]
                    },
                    "unit": "decbytes"
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
                "orientation": "auto",
                "textMode": "auto",
                "wideLayout": true,
                "colorMode": "value",
                "graphMode": "area",
                "justifyMode": "auto",
                "showPercentChange": false
            },
            "targets": [
                {
                    "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
                    "query": "SELECT last(\"bytes\") FROM \"tcpgeo_outgoing_total\" WHERE \"client\" = '$client' AND $timeFilter GROUP BY time($__interval) fill(null)",
                    "rawQuery": true,
                    "refId": "A",
                    "resultFormat": "time_series"
                }
            ]
        },
        {
            "id": 3,
            "type": "stat",
            "title": "Zielländer",
            "description": "Anzahl verschiedener Zielländer",
            "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
            "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
            "fieldConfig": {
                "defaults": {
                    "color": {"fixedColor": "#73BF69", "mode": "fixed"},
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [{"color": "#73BF69", "value": null}]
                    },
                    "unit": "short"
                },
                "overrides": []
