{
    "__inputs": [
        {
            "name": "DS_INFLUXDB",
            "label": "InfluxDB TCPGeo",
            "description": "InfluxDB 1.6 mit tcpgeo Datenbank (z.B. 192.168.66.65:8086)",
            "type": "datasource",
            "pluginId": "influxdb",
            "pluginName": "InfluxDB"
        }
    ],
    "__elements": {},
    "__requires": [
        {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "12.4.0"},
        {"type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0"},
        {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
        {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
        {"type": "panel", "id": "piechart", "name": "Pie chart", "version": ""},
        {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
        {"type": "panel", "id": "table", "name": "Table", "version": ""}
