            "targets": [
                {
                    "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
                    "query": "SELECT last(\"countries_count\") FROM \"tcpgeo_outgoing_total\" WHERE \"client\" = '$client' AND $timeFilter GROUP BY time($__interval) fill(null)",
                    "rawQuery": true,
                    "refId": "A",
                    "resultFormat": "time_series"
                }
            ]
        },
        {
            "id": 4,
            "type": "stat",
            "title": "Events",
            "description": "Verbindungsereignisse im gewählten Zeitraum",
            "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
            "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
            "fieldConfig": {
                "defaults": {
                    "color": {"fixedColor": "#B877D9", "mode": "fixed"},
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [{"color": "#B877D9", "value": null}]
