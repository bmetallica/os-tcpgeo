            "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
            "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
            "fieldConfig": {
                "defaults": {
                    "color": {"fixedColor": "#3274D9", "mode": "fixed"},
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [{"color": "#3274D9", "value": null}]
                    },
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
                "orientation": "auto",
                "textMode": "auto",
                "wideLayout": true,
                "colorMode": "value",
                "graphMode": "none",
                "justifyMode": "auto",
                "showPercentChange": false
            },
            "targets": [
                {
                    "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
                    "query": "SELECT count(distinct(\"client\")) FROM (SELECT last(\"connections\") FROM \"tcpgeo_outgoing_total\" WHERE $timeFilter GROUP BY \"client\")",
                    "rawQuery": true,
                    "refId": "A",
                    "resultFormat": "time_series"
