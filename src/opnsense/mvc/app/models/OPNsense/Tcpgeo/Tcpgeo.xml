<?xml version="1.0" encoding="utf-8"?>
<model>
    <mount>//OPNsense/tcpgeo</mount>
    <version>1.0.0</version>
    <description>TCPGeo Live Traffic Globe Visualization</description>
    <items>
        <general>
            <enabled type="BooleanField">
                <default>0</default>
                <Required>Y</Required>
            </enabled>
            <listeninterface type="InterfaceField">
                <Required>Y</Required>
                <default>lan</default>
                <Multiple>N</Multiple>
                <AllowDynamic>Y</AllowDynamic>
            </listeninterface>
            <listenport type="IntegerField">
                <default>3333</default>
                <MinimumValue>1024</MinimumValue>
                <MaximumValue>65535</MaximumValue>
                <Required>Y</Required>
                <ValidationMessage>Port muss zwischen 1024 und 65535 liegen.</ValidationMessage>
            </listenport>
            <waninterfaces type="InterfaceField">
                <Required>N</Required>
                <default>wan</default>
                <Multiple>Y</Multiple>
                <AllowDynamic>Y</AllowDynamic>
            </waninterfaces>
            <laninterfaces type="InterfaceField">
                <Required>N</Required>
                <default>lan</default>
                <Multiple>Y</Multiple>
                <AllowDynamic>Y</AllowDynamic>
            </laninterfaces>
            <maxmindkey type="TextField">
                <Required>N</Required>
                <Mask>/^[a-zA-Z0-9_]*$/</Mask>
                <ValidationMessage>Nur alphanumerische Zeichen und Unterstriche erlaubt.</ValidationMessage>
            </maxmindkey>
            <globepassword type="TextField">
                <Required>N</Required>
                <Mask>/^$|^.{8,}$/</Mask>
                <ValidationMessage>Passwort muss leer (deaktiviert) oder mindestens 8 Zeichen lang sein.</ValidationMessage>
            </globepassword>
            <maskips type="BooleanField">
                <default>1</default>
                <Required>Y</Required>
            </maskips>
            <showclients type="BooleanField">
                <default>0</default>
                <Required>Y</Required>
            </showclients>
            <enablessl type="BooleanField">
                <default>0</default>
                <Required>Y</Required>
            </enablessl>
            <sslmode type="OptionField">
                <Required>N</Required>
                <default>selfsigned</default>
                <OptionValues>
                    <selfsigned>Selbstsigniert (automatisch)</selfsigned>
                    <opnsense>OPNsense-Zertifikat</opnsense>
                </OptionValues>
            </sslmode>
            <sslcert type="CertificateField">
                <Required>N</Required>
                <Type>cert</Type>
                <ValidationMessage>Bitte ein gültiges Zertifikat auswählen.</ValidationMessage>
            </sslcert>
            <locallat type="TextField">
                <Required>N</Required>
                <default>50.0</default>
                <Mask>/^-?\d{1,3}(\.\d{1,10})?$/</Mask>
                <ValidationMessage>Breitengrad muss eine gültige Zahl sein (z.B. 51.3406).</ValidationMessage>
            </locallat>
            <locallon type="TextField">
                <Required>N</Required>
                <default>10.0</default>
                <Mask>/^-?\d{1,3}(\.\d{1,10})?$/</Mask>
                <ValidationMessage>Längengrad muss eine gültige Zahl sein (z.B. 12.3747).</ValidationMessage>
            </locallon>
            <mqttenabled type="BooleanField">
                <default>0</default>
                <Required>Y</Required>
            </mqttenabled>
            <mqttserver type="TextField">
                <Required>N</Required>
                <Mask>/^[a-zA-Z0-9\.\-\_:]*$/</Mask>
                <ValidationMessage>Hostname oder IP-Adresse des MQTT-Brokers (z.B. 192.168.1.10 oder mqtt.local).</ValidationMessage>
            </mqttserver>
            <mqttport type="IntegerField">
                <default>1883</default>
                <MinimumValue>1</MinimumValue>
                <MaximumValue>65535</MaximumValue>
                <Required>N</Required>
                <ValidationMessage>Port muss zwischen 1 und 65535 liegen.</ValidationMessage>
            </mqttport>
            <mqttusername type="TextField">
                <Required>N</Required>
            </mqttusername>
            <mqttpassword type="TextField">
                <Required>N</Required>
            </mqttpassword>
            <mqtttopic type="TextField">
                <Required>N</Required>
                <default>tcpgeo</default>
                <Mask>/^[a-zA-Z0-9\/\-\_]*$/</Mask>
                <ValidationMessage>Nur alphanumerische Zeichen, Schrägstriche, Bindestriche und Unterstriche erlaubt.</ValidationMessage>
            </mqtttopic>
            <mqttinterval type="IntegerField">
                <default>60</default>
                <MinimumValue>10</MinimumValue>
                <MaximumValue>3600</MaximumValue>
                <Required>N</Required>
                <ValidationMessage>Intervall muss zwischen 10 und 3600 Sekunden liegen.</ValidationMessage>
            </mqttinterval>
        </general>
        <portcolors>
            <portcolor type="ArrayField">
                <enabled type="BooleanField">
                    <default>1</default>
                    <Required>Y</Required>
                </enabled>
                <port type="IntegerField">
                    <MinimumValue>1</MinimumValue>
                    <MaximumValue>65535</MaximumValue>
                    <Required>Y</Required>
                    <ValidationMessage>Port muss zwischen 1 und 65535 liegen.</ValidationMessage>
                </port>
                <color type="TextField">
                    <Required>Y</Required>
                    <default>#00ffff</default>
                    <Mask>/^#[0-9a-fA-F]{6}$/</Mask>
                    <ValidationMessage>Farbe muss ein Hex-Code sein (z.B. #00ffff).</ValidationMessage>
                </color>
                <label type="TextField">
                    <Required>N</Required>
                    <default></default>
                    <ValidationMessage>Optionale Beschreibung für den Port.</ValidationMessage>
                </label>
            </portcolor>
        </portcolors>
    </items>
</model>
